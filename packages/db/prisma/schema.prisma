  user        User      @relation(fields: [userId], references: [id])
  requestType String // ACCOUNT_DELETION, DATA_EXPORT
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, REJECTED
  reason      String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("data_deletion_requests")
}

// =============================================================================
// PHASE 6: VIDYASETU V2 OS EXTENSIONS
// =============================================================================

// --- Learning OS ---

model Concept {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId   String  @db.Uuid
  chapter     Chapter @relation(fields: [chapterId], references: [id])
  name        String
  description String?

  // Phase 4: Deep Content Context
  explanation     String?
  realLifeExample String?
  villageExample  String?

  createdAt             DateTime                @default(now())
  StudentConceptMastery StudentConceptMastery[]
  ConceptActivity       ConceptActivity[]
  ConceptQuiz           ConceptQuiz[]
  ConceptProject        ConceptProject[]
  ConceptSkillMapping   ConceptSkillMapping[]

  @@map("concepts")
}

model LearningGapAnalysis {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String   @db.Uuid
  student          Student  @relation(fields: [studentId], references: [id])
  weakSubjects     String[]
  weakChapters     String[]
  weakConcepts     String[]
  improvementScore Float    @default(0.0)
  studyPlan        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("learning_gap_analyses")
}

model KnowledgeBaseArticle {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question  String
  answer    String
  // Represents a 1536-dimensional vector for OpenAI embeddings
  embedding Json?
  source    String?
  createdAt DateTime @default(now())

  @@map("knowledge_base_articles")
}

// --- Skill OS ---

model SkillPath {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String // Communication, AI Literacy, etc.
  description         String?
  iconUrl             String?
  modules             SkillModule[]
  createdAt           DateTime              @default(now())
  SkillEnrollment     SkillEnrollment[]
  ConceptSkillMapping ConceptSkillMapping[]
  SkillCareerMapping  SkillCareerMapping[]

  @@map("skill_paths")
}

model SkillModule {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skillPathId String    @db.Uuid
  skillPath   SkillPath @relation(fields: [skillPathId], references: [id])
  title       String
  description String?
  content     Json?
  createdAt   DateTime  @default(now())

  @@map("skill_modules")
}

model SkillEnrollment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String    @db.Uuid
  student         Student   @relation(fields: [studentId], references: [id])
  skillPathId     String    @db.Uuid
  skillPath       SkillPath @relation(fields: [skillPathId], references: [id])
  progressPercent Float     @default(0.0)
  certificateUrl  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("skill_enrollments")
}

// --- Innovation OS ---

model InnovationChallenge {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  description    String
  category       String // Science Project, Startup
  points         Int              @default(0)
  createdAt      DateTime         @default(now())
  ConceptProject ConceptProject[]

  @@map("innovation_challenges")
}

model InnovationPortfolio {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String   @db.Uuid
  student     Student  @relation(fields: [studentId], references: [id])
  projectName String
  description String
  mediaUrls   String[]
  score       Float    @default(0.0)
  createdAt   DateTime @default(now())

  @@map("innovation_portfolios")
}

// --- Village Development OS ---

model VillageProjectTemplate {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                    String // e.g., Water Conservation
  description              String
  impactPoints             Int                        @default(0)
  createdAt                DateTime                   @default(now())
  VillageProjectSubmission VillageProjectSubmission[]
  CareerVillageMapping     CareerVillageMapping[]

  @@map("village_project_templates")
}

model VillageProjectSubmission {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String                 @db.Uuid
  student    Student                @relation(fields: [studentId], references: [id])
  templateId String                 @db.Uuid
  template   VillageProjectTemplate @relation(fields: [templateId], references: [id])
  reportText String
  proofUrls  String[]
  status     String                 @default("PENDING") // PENDING, APPROVED
  createdAt  DateTime               @default(now())

  @@map("village_project_submissions")
}

model ParentConsent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId         String    @db.Uuid
  student           Student   @relation(fields: [studentId], references: [id])
  parentUserId      String    @db.Uuid
  parentUser        User      @relation("ParentConsents", fields: [parentUserId], references: [id])
  consentVersion    String    @default("1.0")
  consentGivenAt    DateTime
  consentMethod     String // e.g., OTP_VERIFIED, SCHOOL_FORM, DIGITAL_SIGNATURE
  ipAddress         String?
  deviceFingerprint String?
  isWithdrawn       Boolean   @default(false)
  withdrawnAt       DateTime?
  withdrawnReason   String?
  dataCategories    String[] // e.g., ["academic", "attendance", "behavioral"]
  legalBasis        String    @default("CONSENT")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([studentId])
  @@index([parentUserId])
  @@map("parent_consents")
}

model DataProcessingRecord {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType       String // Student, Teacher
  entityId         String   @db.Uuid
  purpose          String // EDUCATIONAL, SCHOLARSHIP, ANALYTICS, AI_TUTOR
  legalBasis       String
  dataCategories   String[]
  retentionPeriod  Int // days
  thirdPartyShared Boolean  @default(false)
  thirdParties     String[]
  createdAt        DateTime @default(now())

  @@map("data_processing_records")
}

model GrievanceTicket {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation("UserGrievances", fields: [userId], references: [id])
  subject      String
  description  String
  status       String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolution   String?
  resolvedById String?   @db.Uuid
  resolvedBy   User?     @relation("GrievanceResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("grievance_tickets")
}

// =============================================================================
// PHASE 3: LEARNING INTELLIGENCE ENGINE & KNOWLEDGE GRAPH
// =============================================================================

model StudentConceptMastery {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String        @db.Uuid
  student      Student       @relation(fields: [studentId], references: [id])
  conceptId    String        @db.Uuid
  concept      Concept       @relation(fields: [conceptId], references: [id])
  status       MasteryStatus @default(NOT_STARTED)
  masteryScore Float         @default(0.0) // 0 to 100
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())

  @@unique([studentId, conceptId])
  @@map("student_concept_masteries")
}

model StudentGrowthTimeline {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String   @db.Uuid
  student          Student  @relation(fields: [studentId], references: [id])
  monthYear        String // e.g. "2026-06"
  academicGrowth   Float    @default(0.0)
  skillGrowth      Float    @default(0.0)
  innovationGrowth Float    @default(0.0)
  communityGrowth  Float    @default(0.0)
  recordedAt       DateTime @default(now())

  @@unique([studentId, monthYear])
  @@map("student_growth_timelines")
}

model CareerDNAProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId         String   @unique @db.Uuid
  student           Student  @relation(fields: [studentId], references: [id])
  interests         String[]
  topSkillIds       String[]
  calculatedCareers String[] // Array of CareerPath IDs
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@map("career_dna_profiles")
}

// --- Knowledge Graph Mappings ---

model ConceptActivity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId   String   @db.Uuid
  concept     Concept  @relation(fields: [conceptId], references: [id])
  activityRef String // Simple reference to activity/video URL/Lesson module
  createdAt   DateTime @default(now())

  @@map("concept_activities")
}

model ConceptQuiz {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId  String     @db.Uuid
  concept    Concept    @relation(fields: [conceptId], references: [id])
  quizId     String     @db.Uuid
  assessment Assessment @relation(fields: [quizId], references: [id])
  createdAt  DateTime   @default(now())

  @@map("concept_quizzes")
}

model ConceptProject {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId   String              @db.Uuid
  concept     Concept             @relation(fields: [conceptId], references: [id])
  challengeId String              @db.Uuid
  challenge   InnovationChallenge @relation(fields: [challengeId], references: [id])
  createdAt   DateTime            @default(now())

  @@map("concept_projects")
}

model ConceptSkillMapping {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId   String    @db.Uuid
  concept     Concept   @relation(fields: [conceptId], references: [id])
  skillPathId String    @db.Uuid
  skillPath   SkillPath @relation(fields: [skillPathId], references: [id])
  weight      Float     @default(1.0)
  createdAt   DateTime  @default(now())

  @@map("concept_skill_mappings")
}

model SkillCareerMapping {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skillPathId  String     @db.Uuid
  skillPath    SkillPath  @relation(fields: [skillPathId], references: [id])
  careerPathId String     @db.Uuid
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id])
  relevance    Float      @default(1.0)
  createdAt    DateTime   @default(now())

  @@map("skill_career_mappings")
}

model CareerVillageMapping {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  careerPathId String                 @db.Uuid
  careerPath   CareerPath             @relation(fields: [careerPathId], references: [id])
  templateId   String                 @db.Uuid
  template     VillageProjectTemplate @relation(fields: [templateId], references: [id])
  createdAt    DateTime               @default(now())

  @@map("career_village_mappings")
}
