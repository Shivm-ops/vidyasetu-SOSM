// =============================================================================
// VIDYASETU - Complete Database Schema
// Supports: 5M Students | 100K Teachers | 500K Parents | 10K Schools
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  SCHOOL_ADMIN
  PRINCIPAL
  DISTRICT_OFFICER
  NGO_ADMIN
  CSR_ADMIN
  CONTENT_CREATOR
  MENTOR
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Language {
  MARATHI
  ENGLISH
  HINDI
  GUJARATI
  KANNADA
  TRIBAL
}

enum StudentStage {
  FOUNDATION // Class 1-4
  DISCOVERY // Class 5-8
  CAREER // Class 9-12
}

enum ContentType {
  VIDEO
  AUDIO
  TEXT
  PDF
  INTERACTIVE
  GAME
  WORKSHEET
  PRESENTATION
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum AssessmentType {
  QUIZ
  TEST
  EXAM
  PRACTICE
  DIAGNOSTIC
  FORMATIVE
  SUMMATIVE
}

enum MasteryStatus {
  NOT_STARTED
  LEARNING
  PRACTICING
  MASTERED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  LONG_ANSWER
  FILL_BLANK
  MATCH
  ORDER
  DRAW
  VOICE
}

enum DifficultyLevel {
  VERY_EASY
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
  EXAM_DAY
}

enum ScholarshipStatus {
  OPEN
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  AWARDED
  REJECTED
  CLOSED
}

enum MoodType {
  VERY_HAPPY
  HAPPY
  NEUTRAL
  SAD
  VERY_SAD
  ANXIOUS
  EXCITED
  TIRED
}

enum NotificationType {
  ATTENDANCE
  MARKS
  HOMEWORK
  EXAM
  SCHOLARSHIP
  ACHIEVEMENT
  ANNOUNCEMENT
  PARENT_MEETING
  SYSTEM
}

enum CareerCategory {
  ENGINEERING
  MEDICAL
  ARTS
  COMMERCE
  AGRICULTURE
  ITI_DIPLOMA
  GOVERNMENT_JOB
  ENTREPRENEURSHIP
  DEFENSE
  SPORTS
  TEACHING
  TECHNOLOGY
  SKILLED_TRADE
  CREATIVE
}

enum SchoolType {
  GOVERNMENT
  SEMI_GOVERNMENT
  AIDED
  PRIVATE_UNAIDED
  INTERNATIONAL
  TRIBAL_ASHRAM
  KENDRIYA_VIDYALAYA
  NAVODAYA
  NGO_RUN
}

enum Medium {
  MARATHI
  ENGLISH
  URDU
  SEMI_ENGLISH
  HINDI
}

// =============================================================================
// GEOGRAPHY
// =============================================================================

model State {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  nameMarathi String?
  code        String     @unique
  districts   District[]
  createdAt   DateTime   @default(now())

  @@map("states")
}

model District {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  nameMarathi String?
  code        String   @unique
  stateId     String   @db.Uuid
  state       State    @relation(fields: [stateId], references: [id])
  blocks      Block[]
  schools     School[]
  createdAt   DateTime @default(now())

  @@map("districts")
}

model Block {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  nameMarathi String?
  districtId  String    @db.Uuid
  district    District  @relation(fields: [districtId], references: [id])
  villages    Village[]
  schools     School[]
  createdAt   DateTime  @default(now())

  @@map("blocks")
}

model Village {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  nameMarathi     String?
  blockId         String                  @db.Uuid
  block           Block                   @relation(fields: [blockId], references: [id])
  schools         School[]
  users           User[]
  learningCircles VillageLearningCircle[]
  createdAt       DateTime                @default(now())

  @@map("villages")
}

// =============================================================================
// SCHOOL
// =============================================================================

model School {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  udiseCode         String?                   @unique
  name              String
  nameMarathi       String?
  schoolType        SchoolType
  medium            Medium[]
  address           String
  pincode           String
  villageId         String?                   @db.Uuid
  village           Village?                  @relation(fields: [villageId], references: [id])
  blockId           String?                   @db.Uuid
  block             Block?                    @relation(fields: [blockId], references: [id])
  districtId        String                    @db.Uuid
  district          District                  @relation(fields: [districtId], references: [id])
  latitude          Float?
  longitude         Float?
  principalName     String?
  phone             String?
  email             String?
  website           String?
  totalStudents     Int                       @default(0)
  totalTeachers     Int                       @default(0)
  hasElectricity    Boolean                   @default(false)
  hasInternet       Boolean                   @default(false)
  hasComputer       Boolean                   @default(false)
  hasSmartBoard     Boolean                   @default(false)
  hasLibrary        Boolean                   @default(false)
  isActive          Boolean                   @default(true)
  logoUrl           String?
  classes           ClassGrade[]
  users             User[]
  assessments       Assessment[]
  announcements     Announcement[]
  offlineHub        OfflineHub?
  analyticsSnapshot SchoolAnalyticsSnapshot[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([districtId])
  @@index([udiseCode])
  @@map("schools")
}

model ClassGrade {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @db.Uuid
  school    School    @relation(fields: [schoolId], references: [id])
  grade     Int // 1-12
  sections  Section[]
  createdAt DateTime  @default(now())

  @@unique([schoolId, grade])
  @@map("class_grades")
}

model Section {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classGradeId      String             @db.Uuid
  classGrade        ClassGrade         @relation(fields: [classGradeId], references: [id])
  name              String // A, B, C, Div-1
  medium            Medium             @default(MARATHI)
  teacherId         String?            @db.Uuid
  teacher           User?              @relation("ClassTeacher", fields: [teacherId], references: [id])
  enrollments       Enrollment[]
  attendanceRecords AttendanceRecord[]
  timetableSlots    TimetableSlot[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("sections")
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role              UserRole
  phone             String?            @unique
  email             String?            @unique
  passwordHash      String?
  firstName         String
  lastName          String
  firstNameMarathi  String?
  lastNameMarathi   String?
  gender            Gender?
  dateOfBirth       DateTime?
  profilePhotoUrl   String?
  preferredLanguage Language           @default(MARATHI)
  villageId         String?            @db.Uuid
  village           Village?           @relation(fields: [villageId], references: [id])
  schoolId          String?            @db.Uuid
  school            School?            @relation(fields: [schoolId], references: [id])
  isActive          Boolean            @default(true)
  isVerified        Boolean            @default(false)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  lastLoginAt       DateTime?
  fcmToken          String?
  deviceInfo        Json?
  student           Student?
  teacher           Teacher?
  parent            Parent?
  schoolAdmin       SchoolAdmin?
  mentor            Mentor?
  classTeacherOf    Section[]          @relation("ClassTeacher")
  sentMessages      ChatMessage[]      @relation("MessageSender")
  notifications     UserNotification[]
  auditLogs         AuditLog[]
  sessions          UserSession[]
  communityPosts    CommunityPost[]

  // Phase 5: DPDP Compliance
  consentRecords     ConsentRecord[]
  deletionRequests   DataDeletionRequest[]
  parentConsents     ParentConsent[]       @relation("ParentConsents")
  grievances         GrievanceTicket[]     @relation("UserGrievances")
  resolvedGrievances GrievanceTicket[]     @relation("GrievanceResolver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([schoolId])
  @@index([role])
  @@map("users")
}

model UserSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  refreshToken String   @unique
  sessionId    String?
  deviceId     String?
  deviceType   String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model Student {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String                   @unique @db.Uuid
  user                    User                     @relation(fields: [userId], references: [id])
  studentId               String                   @unique // Formatted student ID: VS-2024-00001
  aadhaarHash             String? // Hashed Aadhaar
  grade                   Int
  stage                   StudentStage
  motherName              String?
  fatherName              String?
  guardianName            String?
  castCategory            String? // SC/ST/OBC/OPEN
  isOrphan                Boolean                  @default(false)
  hasDisability           Boolean                  @default(false)
  disabilityType          String?
  isBPL                   Boolean                  @default(false)
  isMigrant               Boolean                  @default(false)
  enrollments             Enrollment[]
  progress                StudentProgress[]
  lessonCompletions       LessonCompletion[]
  assessmentAttempts      AssessmentAttempt[]
  attendanceRecords       AttendanceRecord[]
  careerGoals             CareerGoal[]
  scholarshipApplications ScholarshipApplication[]
  badges                  StudentBadge[]
  learningPoints          LearningPoints?
  moodCheckIns            MoodCheckIn[]
  aiConversations         AIConversation[]
  skillPassport           SkillPassport?
  wellbeingGoals          WellbeingGoal[]
  parentLinks             ParentStudent[]
  parentConsents          ParentConsent[]

  // Phase 3: Intelligence Engine Relations
  learningProfile      LearningIntelligenceProfile?
  dreamCareers         DreamCareer[]
  villageImpacts       VillageImpact[]
  aiProjects           AIProject[]
  teacherInterventions TeacherIntervention[]
  scholarshipMatches   ScholarshipMatch[]
  // Phase 6: VidyaSetu V2 Enterprise OS Scores
  learningScore        Float                        @default(0.0)
  skillScore           Float                        @default(0.0)
  careerReadinessScore Float                        @default(0.0)
  innovationScore      Float                        @default(0.0)
  communityImpactScore Float                        @default(0.0)
  overallGrowthScore   Float                        @default(0.0)

  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  LearningGapAnalysis      LearningGapAnalysis[]
  SkillEnrollment          SkillEnrollment[]
  InnovationPortfolio      InnovationPortfolio[]
  VillageProjectSubmission VillageProjectSubmission[]
  StudentConceptMastery    StudentConceptMastery[]
  StudentGrowthTimeline    StudentGrowthTimeline[]
  CareerDNAProfile         CareerDNAProfile?

  @@index([grade])
  @@index([stage])
  @@index([studentId])
  @@map("students")
}

model Teacher {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @db.Uuid
  user               User               @relation(fields: [userId], references: [id])
  employeeId         String             @unique
  qualification      String?
  specialization     String[]
  subjects           String[]
  experienceYears    Int                @default(0)
  isActive           Boolean            @default(true)
  lessonPlans        LessonPlan[]
  assessmentsCreated Assessment[]
  questionBanks      QuestionBankItem[]
  homeworkAssigned   Homework[]
  attendanceTaken    AttendanceRecord[] @relation("AttendanceTaker")
  aiConversations    AIConversation[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("teachers")
}

model Parent {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @unique @db.Uuid
  user            User             @relation(fields: [userId], references: [id])
  occupation      String?
  income          Float?
  children        ParentStudent[]
  aiConversations AIConversation[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("parents")
}

model ParentStudent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String   @db.Uuid
  parent    Parent   @relation(fields: [parentId], references: [id])
  studentId String   @db.Uuid
  student   Student  @relation(fields: [studentId], references: [id])
  relation  String // MOTHER, FATHER, GUARDIAN
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model SchoolAdmin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  role      String // PRINCIPAL, VICE_PRINCIPAL, ADMIN, CLERK
  createdAt DateTime @default(now())

  @@map("school_admins")
}

model Mentor {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @unique @db.Uuid
  user        User         @relation(fields: [userId], references: [id])
  expertise   String[]
  bio         String?
  bioMarathi  String?
  isAvailable Boolean      @default(true)
  mentorships Mentorship[]
  createdAt   DateTime     @default(now())

  @@map("mentors")
}

model Enrollment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String    @db.Uuid
  student      Student   @relation(fields: [studentId], references: [id])
  sectionId    String    @db.Uuid
  section      Section   @relation(fields: [sectionId], references: [id])
  academicYear String // "2024-25"
  rollNumber   Int?
  isActive     Boolean   @default(true)
  enrolledAt   DateTime  @default(now())
  leftAt       DateTime?

  @@unique([studentId, sectionId, academicYear])
  @@index([sectionId, academicYear])
  @@map("enrollments")
}

// =============================================================================
// CURRICULUM
// =============================================================================

model Subject {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  nameMarathi String?
  nameHindi   String?
  code        String        @unique
  grade       Int? // null means cross-grade
  stage       StudentStage?
  iconUrl     String?
  colorCode   String?
  chapters    Chapter[]
  createdAt   DateTime      @default(now())

  @@map("subjects")
}

model Chapter {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId    String  @db.Uuid
  subject      Subject @relation(fields: [subjectId], references: [id])
  title        String
  titleMarathi String?
  titleHindi   String?
  description  String?
  orderIndex   Int
  grade        Int
  term         Int? // 1 or 2
  iconUrl      String?

  // Phase 4: Intelligence Engine Metadata
  summary            String?
  learningObjectives String[]
  keywords           String[]
  difficultyLevel    DifficultyLevel?

  lessons   Lesson[]
  topics    CurriculumTopic[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  Concept   Concept[]

  @@index([subjectId, grade])
  @@map("chapters")
}

model Lesson {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId          String             @db.Uuid
  chapter            Chapter            @relation(fields: [chapterId], references: [id])
  title              String
  titleMarathi       String?
  titleHindi         String?
  description        String?
  descriptionMarathi String?
  orderIndex         Int
  estimatedMinutes   Int                @default(30)
  difficultyLevel    DifficultyLevel    @default(MEDIUM)
  contentType        ContentType
  status             ContentStatus      @default(DRAFT)
  contents           LessonContent[]
  completions        LessonCompletion[]
  activities         LessonActivity[]
  questionBank       QuestionBankItem[]
  lessonPlans        LessonPlan[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([chapterId])
  @@map("lessons")
}

model LessonContent {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId           String      @db.Uuid
  lesson             Lesson      @relation(fields: [lessonId], references: [id])
  language           Language
  contentType        ContentType
  title              String?
  body               String? // Rich text / HTML
  videoUrl           String?
  videoUrlHLS        String? // HLS stream URL
  audioUrl           String?
  fileUrl            String?
  thumbnailUrl       String?
  durationSecs       Int?
  fileSizeBytes      BigInt?
  isOfflineAvailable Boolean     @default(true)
  orderIndex         Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([lessonId, language])
  @@map("lesson_contents")
}

model LessonActivity {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId            String   @db.Uuid
  lesson              Lesson   @relation(fields: [lessonId], references: [id])
  title               String
  titleMarathi        String?
  activityType        String // DRAWING, GAME, EXPERIMENT, CRAFT, DISCUSSION
  instructions        String?
  instructionsMarathi String?
  materials           String[]
  durationMins        Int?
  ageGroup            String?
  createdAt           DateTime @default(now())

  @@map("lesson_activities")
}

model LessonCompletion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId     String   @db.Uuid
  student       Student  @relation(fields: [studentId], references: [id])
  lessonId      String   @db.Uuid
  lesson        Lesson   @relation(fields: [lessonId], references: [id])
  completedAt   DateTime @default(now())
  timeSpentSecs Int      @default(0)
  watchPercent  Float?
  pointsEarned  Int      @default(0)
  isOffline     Boolean  @default(false)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_completions")
}

// =============================================================================
// ASSESSMENT ENGINE
// =============================================================================

model QuestionBankItem {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId            String?          @db.Uuid
  lesson              Lesson?          @relation(fields: [lessonId], references: [id])
  teacherId           String?          @db.Uuid
  teacher             Teacher?         @relation(fields: [teacherId], references: [id])
  questionType        QuestionType
  difficulty          DifficultyLevel
  grade               Int
  subjectCode         String?
  chapter             String?
  language            Language         @default(MARATHI)
  questionText        String
  questionTextMarathi String?
  questionTextHindi   String?
  questionImageUrl    String?
  options             Json? // [{text, isCorrect, explanation}]
  correctAnswer       String?
  explanation         String?
  explanationMarathi  String?
  tags                String[]
  bloomLevel          String? // REMEMBER, UNDERSTAND, APPLY, ANALYZE, EVALUATE, CREATE
  timeSeconds         Int              @default(60)
  usageCount          Int              @default(0)
  avgScore            Float?
  isAIGenerated       Boolean          @default(false)
  isApproved          Boolean          @default(false)
  assessmentItems     AssessmentItem[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([grade, subjectCode])
  @@index([difficulty])
  @@map("question_bank_items")
}

model Assessment {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String?             @db.Uuid
  school              School?             @relation(fields: [schoolId], references: [id])
  createdById         String              @db.Uuid
  createdBy           Teacher             @relation(fields: [createdById], references: [id])
  title               String
  titleMarathi        String?
  assessmentType      AssessmentType
  grade               Int
  subjectCode         String?
  instructions        String?
  instructionsMarathi String?
  totalMarks          Int
  passingMarks        Int
  durationMinutes     Int
  startTime           DateTime?
  endTime             DateTime?
  isPublished         Boolean             @default(false)
  isRandomized        Boolean             @default(false)
  allowBacktrack      Boolean             @default(true)
  showResult          Boolean             @default(true)
  items               AssessmentItem[]
  attempts            AssessmentAttempt[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  ConceptQuiz         ConceptQuiz[]

  @@index([grade, subjectCode])
  @@map("assessments")
}

model AssessmentItem {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String           @db.Uuid
  assessment   Assessment       @relation(fields: [assessmentId], references: [id])
  questionId   String           @db.Uuid
  question     QuestionBankItem @relation(fields: [questionId], references: [id])
  marks        Int              @default(1)
  orderIndex   Int
  answers      StudentAnswer[]

  @@unique([assessmentId, questionId])
  @@map("assessment_items")
}

model AssessmentAttempt {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String          @db.Uuid
  student         Student         @relation(fields: [studentId], references: [id])
  assessmentId    String          @db.Uuid
  assessment      Assessment      @relation(fields: [assessmentId], references: [id])
  startedAt       DateTime        @default(now())
  submittedAt     DateTime?
  timeSpentSecs   Int             @default(0)
  marksObtained   Float?
  percentScore    Float?
  isPassed        Boolean?
  isAutoSubmitted Boolean         @default(false)
  feedback        String?
  answers         StudentAnswer[]
  createdAt       DateTime        @default(now())

  @@index([studentId, assessmentId])
  @@map("assessment_attempts")
}

model StudentAnswer {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attemptId        String            @db.Uuid
  attempt          AssessmentAttempt @relation(fields: [attemptId], references: [id])
  assessmentItemId String            @db.Uuid
  assessmentItem   AssessmentItem    @relation(fields: [assessmentItemId], references: [id])
  answerText       String?
  answerOptionId   String?
  answerFileUrl    String?
  isCorrect        Boolean?
  marksAwarded     Float?
  aiEvaluation     Json?
  createdAt        DateTime          @default(now())

  @@map("student_answers")
}

// =============================================================================
// HOMEWORK
// =============================================================================

model Homework {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId          String               @db.Uuid
  teacher            Teacher              @relation(fields: [teacherId], references: [id])
  sectionId          String               @db.Uuid
  subjectCode        String
  title              String
  titleMarathi       String?
  description        String?
  descriptionMarathi String?
  dueDate            DateTime
  attachmentUrl      String?
  isAIGenerated      Boolean              @default(false)
  submissions        HomeworkSubmission[]
  createdAt          DateTime             @default(now())

  @@map("homeworks")
}

model HomeworkSubmission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeworkId  String   @db.Uuid
  homework    Homework @relation(fields: [homeworkId], references: [id])
  studentId   String   @db.Uuid
  fileUrl     String?
  textAnswer  String?
  submittedAt DateTime @default(now())
  marks       Float?
  feedback    String?
  isLate      Boolean  @default(false)

  @@unique([homeworkId, studentId])
  @@map("homework_submissions")
}

// =============================================================================
// ATTENDANCE
// =============================================================================

model AttendanceRecord {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String           @db.Uuid
  student   Student          @relation(fields: [studentId], references: [id])
  sectionId String           @db.Uuid
  section   Section          @relation(fields: [sectionId], references: [id])
  date      DateTime         @db.Date
  status    AttendanceStatus
  takenById String           @db.Uuid
  takenBy   Teacher          @relation("AttendanceTaker", fields: [takenById], references: [id])
  remarks   String?
  createdAt DateTime         @default(now())

  @@unique([studentId, sectionId, date])
  @@index([sectionId, date])
  @@index([studentId])
