# =============================================================================
# VIDYASETU Environment Configuration
# =============================================================================

# Application
NODE_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=info

# API Service
API_PORT=3001
API_HOST=0.0.0.0
API_URL=http://localhost:3001
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Web Apps
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_FIREBASE_CONFIG={}

# Database (PostgreSQL)
DATABASE_URL=postgresql://vidyasetu:vidyasetu_pass@localhost:5432/vidyasetu_db
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0
OPENAI_API_KEY=your-openai-key
HUGGINGFACE_API_KEY=your-hf-key
ANTHROPIC_API_KEY=your-anthropic-key
AI_MODEL_NAME=gpt-4o-mini
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_COLLECTION=vidyasetu_knowledge

# Storage (AWS S3 / compatible)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=vidyasetu-content
S3_CDN_URL=https://cdn.vidyasetu.in
CLOUDFRONT_DISTRIBUTION_ID=your-cf-id

# Email (SendGrid / AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-key
EMAIL_FROM=no-reply@vidyasetu.in
EMAIL_FROM_NAME=VidyaSetu

# SMS (Fast2SMS / MSG91)
SMS_PROVIDER=fast2sms
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=VIDSTU

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=vidyasetu-prod
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@vidyasetu-prod.iam.gserviceaccount.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# WhatsApp Business API
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Razorpay (Payments for premium)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Monitoring
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004
